{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "L5 — Complex Schema (conditional fields, enums, arrays of objects)",
    "description": "Complex JSON structure for medical case analysis evaluation",
    "type": "object",
    "required": [
        "patient_id",
        "age",
        "gender",
        "symptoms",
        "diagnosis",
        "treatment_plan"
    ],
    "additionalProperties": false,
    "properties": {
        "patient_id": {
            "type": "string"
        },
        "age": {
            "type": "integer",
            "minimum": 0,
            "maximum": 150
        },
        "gender": {
            "type": "string",
            "enum": [
                "male",
                "female",
                "other"
            ]
        },
        "symptoms": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": [
                    "symptom_name",
                    "severity",
                    "onset",
                    "duration_days"
                ],
                "properties": {
                    "symptom_name": {
                        "type": "string"
                    },
                    "severity": {
                        "type": "string",
                        "enum": [
                            "mild",
                            "moderate",
                            "severe"
                        ]
                    },
                    "onset": {
                        "type": "string",
                        "enum": [
                            "sudden",
                            "gradual"
                        ]
                    },
                    "duration_days": {
                        "type": "integer",
                        "minimum": 0
                    },
                    "is_primary": {
                        "type": "boolean"
                    }
                }
            }
        },
        "diagnosis": {
            "type": "object",
            "required": [
                "condition",
                "icd_code",
                "confidence",
                "differential_diagnoses"
            ],
            "properties": {
                "condition": {
                    "type": "string"
                },
                "icd_code": {
                    "type": "string"
                },
                "confidence": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "stage": {
                    "type": "string",
                    "enum": [
                        "early",
                        "intermediate",
                        "advanced"
                    ]
                },
                "is_chronic": {
                    "type": "boolean"
                },
                "differential_diagnoses": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "required": [
                            "condition",
                            "probability"
                        ],
                        "properties": {
                            "condition": {
                                "type": "string"
                            },
                            "probability": {
                                "type": "number",
                                "minimum": 0,
                                "maximum": 1
                            }
                        }
                    }
                }
            }
        },
        "treatment_plan": {
            "type": "object",
            "required": [
                "approach",
                "medications",
                "follow_up_weeks"
            ],
            "properties": {
                "approach": {
                    "type": "string",
                    "enum": [
                        "conservative",
                        "aggressive",
                        "surgical",
                        "palliative"
                    ]
                },
                "medications": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "required": [
                            "drug_name",
                            "dosage",
                            "frequency"
                        ],
                        "properties": {
                            "drug_name": {
                                "type": "string"
                            },
                            "dosage": {
                                "type": "string"
                            },
                            "frequency": {
                                "type": "string"
                            },
                            "duration_weeks": {
                                "type": "integer"
                            },
                            "contraindications": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                },
                "follow_up_weeks": {
                    "type": "integer",
                    "minimum": 1
                },
                "requires_hospitalization": {
                    "type": "boolean"
                },
                "specialist_referral": {
                    "type": "string"
                }
            }
        },
        "notes": {
            "type": "string"
        }
    }
}